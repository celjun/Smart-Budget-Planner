<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.BudgetPlanner" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/income_green</item>
        <item name="colorPrimaryDark">@color/income_green_dark</item>
        <item name="colorAccent">@color/income_green</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@color/income_green</item>
    </style>

    <!-- Green filled button (Income / Login / Register / Add Entry Income) -->
    <style name="Widget.BudgetPlanner.Button.Green" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/income_green</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">10dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="rippleColor">@color/income_green_dark</item>
    </style>

    <!-- Red filled button (Expense / Add Entry Expense) -->
    <style name="Widget.BudgetPlanner.Button.Red" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/expense_red</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">10dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="rippleColor">@color/expense_red_dark</item>
    </style>

    <!-- Outline button (inactive toggle) -->
    <style name="Widget.BudgetPlanner.Button.Outline" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/border_color</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">13sp</item>
        <item name="cornerRadius">20dp</item>
        <item name="android:paddingTop">8dp</item>
        <item name="android:paddingBottom">8dp</item>
    </style>

    <!-- TextInputLayout style -->
    <style name="Widget.BudgetPlanner.TextInput" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/border_color</item>
        <item name="boxBackgroundColor">@color/input_background</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="boxCornerRadiusTopStart">8dp</item>
        <item name="boxCornerRadiusTopEnd">8dp</item>
        <item name="boxCornerRadiusBottomStart">8dp</item>
        <item name="boxCornerRadiusBottomEnd">8dp</item>
    </style>

    <!-- Card style -->
    <style name="Widget.BudgetPlanner.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/card_background</item>
        <item name="cardElevation">2dp</item>
        <item name="cardCornerRadius">12dp</item>
    </style>

    <!-- Auth button rounded pill -->
    <style name="Widget.BudgetPlanner.Button.Auth" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/income_green</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">24dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>

</resources>
